NODE_ENV=development
PORT=4000

# Postgres connection (local docker-compose default)
DATABASE_URL=postgresql://salary:salary@localhost:5432/salary_management

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Seed HR user
SEED_HR_EMAIL=hr@corp.example
SEED_HR_PASSWORD=password
SEED_HR_NAME=Priya Sharma
